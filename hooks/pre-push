#!/bin/bash
# Pre-push hook: rebuilds the web export and commits it before pushing.

echo "🔨 Building web export before push..."
./build_web.sh || { echo "❌ Build failed — push aborted."; exit 1; }

git add build/build.zip

if git diff --cached --quiet; then
  echo "✅ Build unchanged, nothing to commit."
else
  git commit -m "build: update web export"
  echo "✅ Committed fresh build."
fi

exit 0
